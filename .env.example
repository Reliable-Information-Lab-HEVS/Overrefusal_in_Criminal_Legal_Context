# Example of .env file for api keys
# don't commit the real .env file with api key !

MISTRAL_API_KEY=your-mistral-key-here
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
GEMINI_API_KEY=your-gemini-key-here
PUBLICAI_API_KEY=your_publicai_token_here
# DeepL: one or more keys, comma-separated. Free keys end with ':fx'.
DEEPL_API_KEY=key1:fx,key2